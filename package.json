{
    "name": "vote-tracker",
    "version": "8.0.1",
    "description": "Track, reward, and query Top.gg votes for Discord bots",
    "types": "typings.d.ts",
    "main": "src/index.js",
    "files": [
        "src",
        "typings.d.ts",
        "README.md",
        "CONTRIBUTING.md",
        "SECURITY.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "node --test",
        "check": "node --check src/index.js && node --check src/utils/DiscordUI.js && node --check src/utils/PostHandler.js && node --check src/utils/ReminderHandler.js && node --check src/utils/StatsTracker.js && node --check src/utils/TopggApi.js && node --check src/utils/WebhookVerifier.js",
        "typecheck": "tsc --noEmit --strict --skipLibCheck typings.d.ts"
    },
    "engines": {
        "node": ">=18.18.2"
    },
    "dependencies": {
        "@top-gg/sdk": "^3.1.6",
        "discord.js": "^14.26.4",
        "express": "^5.2.1",
        "topgg-autoposter": "^2.0.2"
    },
    "overrides": {
        "@top-gg/sdk": {
            "undici": "^6.27.0"
        },
        "@discordjs/rest": {
            "undici": "^6.27.0"
        },
        "discord.js": {
            "undici": "^6.27.0"
        }
    },
    "keywords": [
        "top.gg",
        "discord",
        "discord.js",
        "votes",
        "webhook",
        "leaderboard",
        "bot"
    ],
    "author": "hasib9797",
    "repository": {
        "type": "git",
        "url": "https://github.com/hasib9797/vote-tracker"
    },
    "homepage": "https://github.com/hasib9797/vote-tracker#readme",
    "bugs": {
        "url": "https://github.com/hasib9797/vote-tracker/issues"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.0",
        "typescript": "^6.0.3"
    }
}
